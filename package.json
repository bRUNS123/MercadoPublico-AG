{
  "name": "licitaboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Dashboard de Licitaciones de MercadoPúblico Chile",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx --yes gh-pages -d dist",
