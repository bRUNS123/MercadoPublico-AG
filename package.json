    "deploy:snapshot": "npm run snapshot:compra-agil && npm run deploy"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "fflate": "^0.8.3",
    "firebase": "^12.12.0",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.4"
  }
}
