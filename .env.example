# Ticket de la API de Mercado Público (https://api.mercadopublico.cl)
VITE_API_TICKET=tu-ticket-aqui

# Ticket de la API Compra Ágil v2 Beta (https://api2.mercadopublico.cl)
# Por defecto se usa el mismo ticket de arriba (VITE_API_TICKET) — funciona para ambas APIs.
# Solo completa esto si ChileCompra te entrega un ticket distinto para Compra Ágil.
VITE_API_TICKET_COMPRA_AGIL=

# URL del proxy CORS para Compra Ágil en producción (Cloudflare Worker, plan gratuito).
# Ver cloudflare-worker/compra-agil-proxy.js para desplegarlo. Déjalo vacío para usar la
# URL directa (fallará por CORS en GitHub Pages hasta que despliegues el proxy).
VITE_COMPRA_AGIL_PROXY_URL=

# Configuración de Firebase (Opcional, para colaboración en tiempo real)
# Ve a console.firebase.google.com, crea un proyecto web y pega las variables aquí:
VITE_FIREBASE_API_KEY=tu-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
